# DB接続（必須）
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=あなたのMySQLパスワード
DB_NAME=seoscan

# メール送信（いずれか設定）
# 方法1: Gmail SMTP（開発向け）
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=アプリパスワード（Googleアカウントで2段階認証→アプリパスワードを発行）
# 方法2: AWS SES（本番向け）
# SES_FROM=verified-sender@example.com
# AWS_REGION=ap-northeast-1

# クロール上限（本番デフォルト: 5000、開発: 1000。上書き可能）
# MAX_CRAWL_PAGES=5000

# クロールタイムアウト（デフォルト: 15分。大規模サイトは延長を推奨）
# CRAWL_RUN_TIMEOUT_MS=900000
# CRAWL_JOB_TIMEOUT_MS=900000

# Google OAuth（GSC 連携・ユーザーごとに Google ログイン）
# Google Cloud Console で OAuth 2.0 クライアント ID を作成し、リダイレクト URI を登録:
#   http://localhost:3000/api/auth/google/callback （開発）
#   https://yourdomain.com/api/auth/google/callback （本番）
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# APP_URL=https://yourdomain.com （本番時、リダイレクト URI のベース）

# 運用型広告 API（ADs ページ）
# OAuth には上記 GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET（GSC 連携と同じ）を使用
# Google Cloud Console の OAuth クライアントに以下をリダイレクト URI として追加:
#   http://localhost:3000/api/ads/google/callback （開発）
#   https://yourdomain.com/api/ads/google/callback （本番）
# GOOGLE_ADS_DEVELOPER_TOKEN=xxx （Google Ads Manager で取得・要承認）

# Yahoo! 広告 API
# YAHOO_ADS_ACCESS_TOKEN=xxx
# YAHOO_ADS_ACCOUNT_ID=xxx

# Microsoft Advertising API
# MICROSOFT_ADS_CLIENT_ID=xxx
# MICROSOFT_ADS_CLIENT_SECRET=xxx
# MICROSOFT_ADS_REFRESH_TOKEN=xxx
# MICROSOFT_ADS_CUSTOMER_ID=xxx
